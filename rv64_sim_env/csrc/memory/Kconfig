menu "Memory Configuration"

config MBASE
  hex "Memory base address"
  default 0x80000000

config MSIZE # 4MB
  hex "Memory size"
  default 0x400000 # ysyxSoC=0x400000=4MB npc=0x8000000=256MB

config MROM_BASE
  hex "MROM base address"
  default 0x20000000

config MROM_SIZE # 4KB
  hex "MROM size"
  default 0x1000

config FLASH_BASE
  hex "FLASH base adress"
  default 0x30000000

config FLASH_SIZE # 16MB
  hex "FLASH size"
  default 0x1000000

config SDRAM_BASE
  hex "SDRAM base adress"
  default 0xa0000000

config SDRAM_SIZE # 32MB -> *4=128MB
  hex "SDRAM size"
  # default 0x2000000
  default 0x8000000

config VMEM_BASE
  hex "SDRAM base"
  default 0x21000000

config VMEM_SIZE
  hex "Vedio memory size"
  default 307200 # 640 * 480

config PC_RESET_OFFSET
  hex "Offset of reset vector from the base of memory"
  default 0x100000 if ISA_x86
  default 0

choice
  prompt "Physical memory definition"
  default PMEM_GARRAY
config PMEM_MALLOC
  bool "Using malloc()"
config PMEM_GARRAY
  depends on !TARGET_AM
  bool "Using global array"
endchoice

config MEM_RANDOM
  depends on MODE_SYSTEM && !DIFFTEST && !TARGET_AM
  bool "Initialize the memory with random values"
  default y
  help
    This may help to find undefined behaviors.

endmenu #MEMORY
